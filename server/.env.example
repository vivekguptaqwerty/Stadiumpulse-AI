# Express Server Config
# Note: PORT=3001 is for local development. In production (Cloud Run), the PORT variable is automatically injected.
PORT=3001
NODE_ENV=development

# AI Settings (options: gemini, mock)
AI_PROVIDER=gemini

# Pinned Gemini Model Settings
# Default is gemini-3.5-flash. Change only if overridden.
GEMINI_MODEL=gemini-3.5-flash

# Google Gemini API Settings
# Get an API key from Google AI Studio (https://aistudio.google.com/)
# IMPORTANT: Never commit the real key to Git or bake it into the Docker image.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
