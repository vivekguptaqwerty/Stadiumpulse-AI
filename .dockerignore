# Exclude development files and folders from Docker context
.git
.gitignore
**/node_modules
**/.env
**/.env.*
!**/.env.example
client/dist
server/dist
submission-assets
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.idea
.vscode
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
